{
  "name": "grafiki-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "prepare-sidecar:debug": "bash ../../scripts/prepare_desktop_sidecar.sh debug",
    "prepare-sidecar:release": "bash ../../scripts/prepare_desktop_sidecar.sh release",
    "tauri": "tauri",
    "tauri:build:debug": "npm run prepare-sidecar:debug && tauri build --debug",
    "tauri:build:release": "npm run prepare-sidecar:release && tauri build",
    "test:e2e": "npm run build && cargo build -p grafiki-desktop && wdio run wdio.conf.js",
    "test:e2e:only": "wdio run wdio.conf.js"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-service": "^1.2.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "@wdio/native-utils": "2.5.0"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  }
}